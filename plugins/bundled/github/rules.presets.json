{
  "presets": [
    {
      "name": "Notify on failed workflows",
      "description": "Adds workflow failures to the Status inbox and shows a local notification when enabled.",
      "when": {
        "eventType": "github.workflow.failed",
        "provider": "com.status.github"
      },
      "if": [
        {
          "field": "severity",
          "operator": "matches_severity",
          "value": "warning"
        }
      ],
      "then": [
        {
          "action": "status.inbox.add"
        },
        {
          "action": "notification.show"
        }
      ]
    }
  ]
}
